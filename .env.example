# Copy this file to ".env" and fill in your values, then run: node web-console.js
# .env is gitignored — never commit real secrets.

# ── AnyList (leave commented out to use the offline mock) ──────────────────
USE_REAL_ANYLIST=1
ANYLIST_EMAIL=your-anylist-email@example.com
ANYLIST_PASSWORD=your-anylist-password

# ── Claude brain (leave commented out to use the offline mock brain) ───────
ANTHROPIC_API_KEY=sk-ant-...

# ── Auth (REQUIRED before hosting the console publicly — it can edit your lists) ──
# AUTH_USER=family
# AUTH_PASS=pick-a-strong-password

# ── Optional tuning ────────────────────────────────────────────────────────
# CLAUDE_MODEL=claude-sonnet-4-5
# DIAL=balanced          # balanced | cautious | aggressive
# DEFAULT_LIST=Shared Grocery List   # which list unspecified items go to (else a "grocery" list, else the first)
# WEB_PORT=4000          # web console port
# PORT=3000              # SMS server port
